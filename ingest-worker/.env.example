INGEST_SECRET=change-me-to-a-random-secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
PORT=3001

# Lesson generation. Precedence: Anthropic (preferred — matches the inline
# path; the worker has no 60s cap so Opus is fine) -> OpenRouter -> templated.
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_MODEL=claude-opus-4-8
# Fallback generator if ANTHROPIC_API_KEY is unset:
OPENROUTER_API_KEY=your-openrouter-key
OPENAI_MODEL=gpt-4.1-mini

# Supadata managed transcript API key. Required: transcript fetching is
# delegated to Supadata, which absorbs YouTube's datacenter-IP blocking and
# PoToken bot-detection server-side. Get a key (free tier available) at
# https://supadata.ai. Without it, the worker fails closed.
SUPADATA_API_KEY=your-supadata-key
